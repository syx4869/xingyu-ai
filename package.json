{
  "name": "xiyu-ai",
  "version": "1.21.4",
  "type": "module",
  "description": "星语 AI · 开源的微信 AI 陪伴系统。支持 DeepSeek / OpenAI / Claude / xAI / 智谱 / 豆包 / 千问 / Kimi / 文心 等多种大模型",
  "license": "MIT",
  "main": "index.mjs",
  "scripts": {
    "start": "node index.mjs",
    "dev": "node --watch index.mjs",
    "setup": "node scripts/setup-wizard.mjs",
    "setup:full": "bash scripts/setup.sh",
    "ilink:login": "node scripts/ilink_login.mjs",
    "doctor": "node scripts/doctor.mjs",
    "lint": "eslint src scripts index.mjs",
    "check:p0": "node scripts/p0_regression_check.mjs",
    "check:imports": "node scripts/import_smoke.mjs",
    "scan:ai-taste": "node scripts/ai_taste_scan.mjs",
    "check:field-drift": "node scripts/check_summary_field_drift.mjs",
    "check:release": "node scripts/check-release-consistency.mjs",
    "arc:digest": "node scripts/arc-digest.mjs",
    "stickers:fetch": "python3 scripts/fetch_stickers.py",
    "smoke": "bash scripts/release_smoke_test.sh",
    "postinstall": "wx-voice compile || echo '[postinstall] wx-voice compile failed (语音功能将不可用，先忽略)'"
  },
  "keywords": [
    "ai-companion",
    "wechat",
    "chatbot",
    "deepseek",
    "openai",
    "claude",
    "zhipu",
    "qwen",
    "doubao",
    "kimi",
    "wenxin",
    "xai"
  ],
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@tencent-weixin/openclaw-weixin-cli": "^2.1.4",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.4.5",
    "express": "^5.2.1",
    "form-data": "^4.0.0",
    "node-fetch": "^3.3.2",
    "openai": "^4.67.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "sharp": "^0.34.5",
    "wx-voice": "^0.2.1"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.4.1"
  }
}
