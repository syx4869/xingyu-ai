# ─────────────────────────────────────────────────────────────────────────
# 星语 AI · 环境变量样例
# 把本文件复制为 .env，按需填写。
# 至少需要：一个 chat provider 的 key + 一个 image provider 的 key（可选）
#         + 一个 ASR provider 的 key（可选）
# ─────────────────────────────────────────────────────────────────────────

# ════════════════ 1. AI Provider 选择 ════════════════
# 文本对话 (必填)：deepseek | openai | anthropic | xai | zhipu | doubao | qwen | kimi | wenxin | ollama
# v1.9.8 新增 ollama 预设：本地零 API 成本跑大模型，见末尾 section 8
CHAT_PROVIDER=deepseek
CHAT_MODEL=                            # 留空使用默认；豆包必须填火山方舟接入点 ID (ep-xxx)

# 图像生成 (可选)：zhipu | qwen | doubao | wenxin | openai
IMAGE_PROVIDER=zhipu
IMAGE_MODEL=                           # 留空用各家默认（zhipu=cogview-4, qwen=wanx-v1, openai=gpt-image-1）

# 图片识别 (可选)：zhipu | openai | qwen | doubao | anthropic
VISION_PROVIDER=zhipu
VISION_MODEL=

# 语音识别 (可选)：gemini | openai | qwen | xunfei | tencent
ASR_PROVIDER=gemini
ASR_MODEL=

# 文本向量化 (用于长期记忆语义检索)：gemini | openai | zhipu | qwen
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=
EMBEDDING_DIM=768

# ════════════════ 2. 各家 API Keys（按需填写所选 provider 那一行）═════════
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
ZHIPU_API_KEY=
DOUBAO_API_KEY=                        # 火山方舟 API Key
QWEN_API_KEY=                          # 阿里 DashScope API Key（也用于 image/asr/embedding）
KIMI_API_KEY=                          # Moonshot
WENXIN_API_KEY=                        # 百度千帆
GEMINI_API_KEY=                        # 用于 ASR 和 embedding 默认 provider

# 讯飞 ASR (可选，仅在 ASR_PROVIDER=xunfei 时使用)
XUNFEI_APP_ID=
XUNFEI_API_KEY=
XUNFEI_API_SECRET=

# ════════════════ 3. 微信接入 (腾讯 iLink ClawBot) ════════════════
# 不接入微信只用网页测试 chat 时这块可以留空
ILINK_BASE_URL=https://ilinkai.weixin.qq.com
ILINK_BOT_TOKEN=
ILINK_BOT_ID=
ILINK_USER_ID=
GET_UPDATES_BUF=5
POLL_INTERVAL_MS=1500
WECHAT_TOKEN_ENC_KEY=                  # iLink CDN 媒体加密 key

# iLink API paths（如官方调整时覆盖）
ILINK_GET_UPDATES_PATH=
ILINK_SEND_MSG_PATH=
ILINK_GET_MEDIA_PATH=

# ════════════════ 4. 邮件 (验证码) ════════════════
# 模式自动判断：
#   · 配了 RESEND_API_KEY + RESEND_FROM     → 真实发邮件（Resend）
#   · 任一缺失                              → dev_stdout（验证码直接打到服务日志）
# 想强制 dev 模式（哪怕配了 RESEND）：EMAIL_MODE=dev_stdout 或 EMAIL_DEV_MODE=1
EMAIL_MODE=
EMAIL_DEV_MODE=
RESEND_API_KEY=
RESEND_FROM=

# ════════════════ 5. 应用配置 ════════════════
DB_PATH=./data/bot.db
LOG_LEVEL=info                         # debug | info | warn | error
API_PORT=3000
# AUTH_SECRET 留空会自动生成到 .auth-secret 并持久化
AUTH_SECRET=

# v1.5.1 单用户模式：跳过登录页，启动后直接进 dashboard。
# ⚠️ 仅在以下场景开启：
#   · 本机 localhost 自己玩
#   · 家用 NAS / 内网信任环境
#   · 公网部署但前置 nginx Basic Auth / Cloudflare Access / IP 白名单
# 如果服务直接暴露公网（无任何前置保护），开启此项 = 所有聊天记录/记忆/绑定信息对全世界开放！
# 默认 false（多用户模式，与原行为完全兼容）
SINGLE_USER=false

# ════════════════ 6. 真实感 / Inner OS（v1.8.2+） ════════════════
# Inner OS 双重思考：在生成对外回复前，先让她生成一段"内心独白"，
# 再基于此写回复。落差 = 真人感。代价 ≈ 2x token。
#
# INNER_OS_MODE: off | selective | always（默认 always）
#   · always    — 默认。长消息都跑；关系张力短句（哦/睡了？/在干嘛/你变了…）也跑。
#   · selective — 仅长消息命中情绪触发词（烦/累/想你/分手/为什么不…）才跑；省 token。
#   · off       — 完全关闭。
# 旧 INNER_OS_ENABLED=false 仍然兼容（等价 mode=off）。
INNER_OS_MODE=always
# 长消息门槛（字符数），低于此长度的消息只有命中"关系张力短句白名单"才跑
INNER_OS_MIN_LEN=8
# 内心独白生成的 max_tokens（v1.21 起默认 160——末行多产一行冲突弧结构化 JSON）
INNER_OS_MAX_TOKENS=160

# ─── 冲突与和好弧（v1.21，docs/CONFLICT_ARC.md）──────────────────────────
# ARC_MAX_STATE：运维钳位保险丝（默认空 = 不钳）。取值 hurt | cold | withdrawing：
# 状态机只能升到该上限，事件照常建档落库（数据不丢，只钳状态与表达），
# 已超限的存量状态会在 30 分钟批内被压回。生产误伤时免回滚的应急旋钮。
# ⚠ 与未成年人保护性质相反：safe_mode 是安全底线、无关闭开关、不可配置；
#   这是"冲突弧"这个风险功能的可调上限。
# ARC_MAX_STATE=
# 其余 ARC_* 调参（每日事件上限/消化时长/warm 需求等）见 docs/CONFLICT_ARC.md §7

# ─── proactive 死人开关（v1.21.2，#263 事故后续）────────────────────────
# 每小时心跳：近 6h 有活跃对话的 companion > 0 但 proactive 成功发送 = 0，
# 连续 2 个周期 → CRITICAL 日志 + 运维告警邮件（复用 Resend 通道）。
# 纯报警零自愈。未配置邮箱时只打 CRITICAL 日志。夜间（上海 23-9 点）不判定。
# ADMIN_ALERT_EMAIL=ops@example.com

# ════════════════ 7. Provider 重试 / 韧性（v1.9.0+） ════════════════
# 单 provider 内部 retry：429/5xx/超时/网络错按指数退避重试。
# 不做跨 provider fallback（开源用户大多自己接 1 个 provider，无需路由层）。
# 退避节奏：BASE × 3^attempt × jitter(±20%) = 250 / 750 / 2250 ms（默认）
PROVIDER_RETRY_MAX=2
# 退避基线（毫秒），调高让重试更耐心，调低更激进
PROVIDER_RETRY_BASE_DELAY_MS=250

# ════════════════ 8. Ollama 本地模型预设（v1.9.8） ════════════════
# 想完全本地、零 API 成本运行？三步：
#   1. 装 Ollama: https://ollama.com/  (官方一键脚本)
#   2. 拉模型:   ollama pull qwen2.5:7b   (或 llama3:8b / deepseek-r1:7b 等)
#   3. 改两行 .env: CHAT_PROVIDER=ollama  +  OLLAMA_MODEL=qwen2.5:7b
# Ollama 默认不鉴权，OLLAMA_API_KEY 填占位字符串即可（不能空）
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=
OLLAMA_API_KEY=ollama

# ════════════════ 9.5. 破冰延迟（v1.9.11） ════════════════
# 用户长时间沉默后第一条消息，回复时加额外延迟，模拟"她刚看到、想想怎么回"。
# 触发阈值（分钟）：沉默 ≥ 这么久才算"破冰"
ICEBREAKER_SILENCE_MIN_MIN=30
# 额外延迟范围（毫秒）：沉默 30min 用 MIN，沉默 24h+ 用 MAX，中间线性插值 + ±25% jitter
ICEBREAKER_DELAY_MIN_MS=5000
ICEBREAKER_DELAY_MAX_MS=20000

# ════════════════ 9. 长期记忆压缩（v1.9.8） ════════════════
# 每月 1 号 3:00 自动跑：把 N 天前的零碎 fact/event/emotion 合并成"老记忆压缩"
# 摘要（按月分组），删除原条目。避免半年/一年后记忆无限膨胀。
# 不动 preference（稳定特征）/ pinned（用户钉住）/ 已有 summary 类型。
# 默认 90 天。最小 30 天。
MEMORY_COMPACT_DAYS=90

# ════════════════ 10. Cloudflare Turnstile 人机验证（v1.10.0） ════════════════
# 注册页发送邮箱验证码前先验人机（防刷邮件配额）。
# Site key 在 public/app/auth.html 硬编码（无敏感性）；这里只放 server-side secret。
# 留空 → 整个 Turnstile 校验跳过（dev 环境方便测试，但 prod 必须填）。
# 申请：https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET=
